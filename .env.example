BOT_TOKEN=123456789:AAGASD2cxfatkDasDE22dqfawdfawd2WD-UI
BOT_DEV_ID=123456789
BOT_GROUP_ID=-100123456789
BOT_EMOJI_ID=5417915203100613993
# Юзернейм основного бота без @ (deep link из /information: t.me/BOT?start=user_<id>)
BOT_USERNAME=

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Groq (https://console.groq.com) — пустой ключ = ИИ отключён
# Без кавычек: GROQ_API_KEY=gsk_...  |  при 403: новый ключ, проверить env в контейнере
GROQ_API_KEY=
# false — не вызывать ИИ (история для контекста не пишется)
GROQ_ENABLED=true
# Быстрая модель по умолчанию; можно llama-3.3-70b-versatile и др.
GROQ_MODEL=llama-3.1-8b-instant
# После ответа оператора в топике ИИ не отвечает в ЛС N секунд (не ниже 3600 = 1 ч); по истечении — снова может отвечать в том же топике
GROQ_OPERATOR_LOCK_SEC=3600
# Vision: фото + подпись → ИИ анализирует изображение; только фото без подписи — пропуск
# false по умолчанию (лимит бесплатного тира: 1000 запросов/день)
GROQ_VISION_ENABLED=false
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
