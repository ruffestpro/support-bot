BOT_DEV_ID=123456789
BOT_GROUP_ID=-100123456789
BOT_EMOJI_ID=5417915203100613993
# Юзернейм основного бота без @ (deep link из /information: t.me/BOT?start=user_<id>)
BOT_USERNAME=

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Groq (https://console.groq.com) — пустой ключ = ИИ отключён
# Без кавычек: GROQ_API_KEY=gsk_...  |  при 403: новый ключ, проверить env в контейнере
GROQ_API_KEY=
# false — не вызывать ИИ (история для контекста не пишется)
GROQ_ENABLED=true
# Быстрая модель по умолчанию; можно llama-3.3-70b-versatile и др.
GROQ_MODEL=llama-3.1-8b-instant
